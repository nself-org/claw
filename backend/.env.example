# nClaw Backend Configuration
# Requires nSelf CLI and pro license

PROJECT_NAME=nclaw
ENV=dev
BASE_DOMAIN=localhost

# Required Pro Plugins
# nself plugin install ai mux claw

# AI Configuration
AI_DEFAULT_PROVIDER=ollama
AI_OLLAMA_ENABLED=true
# Provider API keys configured via: nself config set ai.provider_1.api_key <key>

# Email Pipeline (optional, for nself-mux)
MUX_ENABLED=false
