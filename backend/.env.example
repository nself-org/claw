# ɳClaw Backend Configuration
# Requires nSelf CLI and a Max license ($19/yr)
# Get a license: https://nself.org/pricing
# Requires nSelf Max license — https://nself.org/pricing

PROJECT_NAME=nclaw
ENV=dev
BASE_DOMAIN=localhost

# =============================================================================
# Max Plugins License — REQUIRED for ɳClaw
# =============================================================================
# ɳClaw requires a nSelf Max license ($19/yr).
# After purchasing, set your key and install the required plugins:
#
#   nself license set nself_pro_xxxxxxxxxxxxxxxxxxxxxxxx
#   nself plugin install ai mux claw notify cron
#   nself build && nself start
#
NSELF_PLUGIN_LICENSE_KEY=nself_pro_your_key_here  # Max tier ($19/yr) — requires valid license key

# =============================================================================
# AI Configuration
# =============================================================================
AI_DEFAULT_PROVIDER=ollama
AI_OLLAMA_ENABLED=true
# Provider API keys configured via: nself config set ai.provider_1.api_key <key>

# =============================================================================
# Email Pipeline (nself-mux)
# =============================================================================
MUX_ENABLED=false
