# nClaw Android App — Environment Configuration
# Copy to local.properties and add the android-specific build properties.
# local.properties is excluded from git by default.

# ============================================================
# Required: Your nSelf server URL
# Set in gradle.properties or via BuildConfig
# ============================================================
CLAW_SERVER_URL=https://your-server.example.com

# ============================================================
# Optional: Build configuration
# ============================================================

# FCM Sender ID — get from Firebase Console
# FCM_SENDER_ID=

# Enable voice mode (requires nself-voice plugin on server)
VOICE_ENABLED=false

# Android Keystore for release signing
# KEYSTORE_PATH=
# KEYSTORE_ALIAS=
# KEYSTORE_PASSWORD=
# KEY_PASSWORD=
