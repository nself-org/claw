# nClaw iOS App — Environment Configuration
# These values are typically set in Xcode build settings or via a .xcconfig file.
# For development, copy to Config/Debug.xcconfig (excluded from git).

# ============================================================
# Required: Your nSelf server URL
# ============================================================
CLAW_SERVER_URL = https://your-server.example.com

# ============================================================
# Optional: Build configuration
# ============================================================

# Bundle identifier suffix (e.g. .debug, .staging, empty for prod)
BUNDLE_ID_SUFFIX =

# APNs environment: development | production
APNS_ENVIRONMENT = development

# Enable voice mode UI (requires nself-voice plugin on server)
VOICE_ENABLED = NO

# ============================================================
# Secure Enclave
# ============================================================
# Encryption key tag — must be unique per app installation
# E2E_KEY_TAG = org.nself.claw.e2ekey
