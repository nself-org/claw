# nClaw Web Client — Environment Configuration
# Copy to .env.local and fill in your values

# ============================================================
# Required: Your nSelf server URL (where nself-claw is running)
# ============================================================
NEXT_PUBLIC_CLAW_SERVER_URL=https://your-server.example.com

# ============================================================
# Optional: Default settings
# ============================================================

# JWT for authenticating with nself-claw (obtained after login)
# Do not set this here — it is stored in localStorage by the app
# NEXT_PUBLIC_CLAW_JWT=

# Enable voice mode (requires nself-voice plugin on the server)
NEXT_PUBLIC_VOICE_ENABLED=false

# Theme: light | dark | system
NEXT_PUBLIC_DEFAULT_THEME=system

# WebSocket reconnect delay in ms
NEXT_PUBLIC_WS_RECONNECT_MS=3000

# ============================================================
# Build-time only (not exposed to browser)
# ============================================================

# Optional: analytics endpoint (internal use only)
# CLAW_ANALYTICS_URL=
